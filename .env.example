# ===================================================================
# Environment Variables — copy to .env and fill in real values
# NEVER commit your real .env file (it's in .gitignore)
# ===================================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database ---
DB_PATH=server/db/store.db

# --- Auth: bcrypt + JWT ---
# Generate a strong random secret (e.g., `openssl rand -hex 32`)
JWT_SECRET=replace_me_with_a_long_random_secret_string
JWT_EXPIRES=24h
BCRYPT_ROUNDS=10

# --- CORS whitelist (comma-separated) ---
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# --- Simulated Microservice (Session 9) ---
WORKSHOP_SERVICE_URL=http://localhost:3000/api/workshops
